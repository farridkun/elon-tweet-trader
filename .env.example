# =============================================================================
# Elon Tweet Trader — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values, or export each variable
# directly in your shell / deployment environment.
#
# Config priority: config.json > environment variables > defaults
# Most settings below already have sensible defaults (see config.json).
# You only NEED to set SIMMER_API_KEY (and WALLET_PRIVATE_KEY for live trading).
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Simmer API key — get it from simmer.markets/dashboard → SDK tab
SIMMER_API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# Required for live trading
# -----------------------------------------------------------------------------

# Private key of your Polymarket wallet (the wallet that holds USDC.e on Polygon).
# The Simmer SDK uses this to sign orders client-side — no manual signing needed.
# IMPORTANT: keep this secret and never commit it to version control.
WALLET_PRIVATE_KEY=0xyour-polymarket-wallet-private-key

# -----------------------------------------------------------------------------
# Data source
# -----------------------------------------------------------------------------

# Where to fetch Elon's real-time tweet count and pace projection.
#
# Supported values:
#   xtracker  — Uses the public XTracker API at https://xtracker.polymarket.com
#               No API key or sign-up required. This is the default and the
#               only supported source right now — you do NOT need to change it.
#
# Default: xtracker
# SIMMER_ELON_DATA_SOURCE=xtracker

# -----------------------------------------------------------------------------
# Trading strategy (all optional — defaults shown)
# -----------------------------------------------------------------------------

# Only buy a bucket cluster if the sum of prices is below this threshold.
# Lower = stricter edge requirement. Default: 0.90 ($0.90)
# SIMMER_ELON_MAX_BUCKET_SUM=0.90

# Maximum USD to spend per individual bucket.
# SIMMER_ELON_MAX_POSITION=5.00

# Number of neighboring buckets to buy on each side of the projected bucket.
# 1 = center ± 1 = 3 buckets total. Higher values give wider coverage.
# SIMMER_ELON_BUCKET_SPREAD=1

# With --smart-sizing, position size = this fraction of your USDC balance.
# 0.05 = 5 %. Capped by SIMMER_ELON_MAX_POSITION.
# SIMMER_ELON_SIZING_PCT=0.05

# Minimum position size in USD (floor for smart sizing).
# SIMMER_ELON_MIN_POSITION=2.00

# Maximum trades to execute per scan cycle.
# SIMMER_ELON_MAX_TRADES=6

# Sell open positions when the bucket price rises above this fraction.
# 0.65 = exit at 65 ¢ on the dollar.
# SIMMER_ELON_EXIT=0.65

# Skip a trade if estimated slippage exceeds this fraction.
# 0.05 = 5 % slippage tolerance.
# SIMMER_ELON_SLIPPAGE_MAX=0.05

# -----------------------------------------------------------------------------
# Optional / advanced
# -----------------------------------------------------------------------------

# Override position size globally (takes precedence over smart sizing).
# AUTOMATON_MAX_BET=10.00

# Trading venue. Only "polymarket" is supported.
# TRADING_VENUE=polymarket

# Set to "true" if this skill is running inside an automation/managed platform.
# AUTOMATON_MANAGED=false
